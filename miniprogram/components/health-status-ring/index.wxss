.status-ring {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.status-ring__circle {
  width: 104px;
  height: 104px;
  border-radius: 50%;
  border: 10px solid var(--color-primary-soft);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}

.status-ring__circle--attention {
  border-color: rgba(242, 166, 90, 0.32);
}

.status-ring__circle--warning {
  border-color: rgba(232, 121, 109, 0.32);
}

.status-ring__number {
  font-size: var(--font-number-large);
  line-height: 1;
  font-weight: 800;
}

.status-ring__label {
  margin-top: 4px;
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.status-ring__content {
  flex: 1;
  min-width: 0;
}

.status-ring__title {
  font-size: var(--font-card-title);
  font-weight: 800;
  line-height: 1.35;
}

.status-ring__item,
.status-ring__tip {
  margin-top: 6px;
  color: var(--color-text-secondary);
  font-size: var(--font-body-small);
  line-height: 1.45;
}

.status-ring__tip {
  color: var(--color-text-muted);
  font-size: var(--font-caption);
}
