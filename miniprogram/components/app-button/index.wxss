.app-button {
  width: 100%;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  box-sizing: border-box;
  padding: 0 18px;
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  font-weight: 700;
  line-height: 1.2;
}

/* 去掉微信原生 button 的默认边框和外边距，避免在 grid 内撑破布局 */
.app-button::after {
  border: none;
}

.app-button--primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  box-shadow: 0 6px 18px rgba(79, 119, 101, 0.24);
}

.app-button--disabled {
  opacity: 0.55;
  box-shadow: none;
}

.app-button--secondary {
  background: var(--color-primary-soft);
  color: var(--color-primary-deep);
}

.app-button--plain {
  background: var(--color-surface-soft);
  color: var(--color-text-primary);
}

.app-button--text {
  min-height: 40px;
  padding: 0 8px;
  background: transparent;
  color: var(--color-primary-deep);
  box-shadow: none;
}
