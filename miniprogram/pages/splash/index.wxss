/* 启动页：位图主视觉 + 底部品牌字叠加 */

.splash {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: #f8f6f1; /* 图片加载前的兜底色 */
}

/* 主视觉位图：铺满整屏，aspectFill 保证不畸变且填满 */
.splash-art {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 底部品牌区可读性兜底：向下的渐变遮罩，避免文字压在杂乱背景上 */
.brand {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 160rpx 48rpx calc(env(safe-area-inset-bottom) + 96rpx);
  text-align: center;
  background: linear-gradient(
    to top,
    rgba(248, 246, 241, 0.92) 0%,
    rgba(248, 246, 241, 0.6) 55%,
    rgba(248, 246, 241, 0) 100%
  );
}

.brand__title {
  font-family: 'Iowan Old Style', 'Songti SC', 'Noto Serif SC', Georgia, serif;
  font-size: 80rpx;
  line-height: 1;
  letter-spacing: 0.08em;
  color: #2f6f65; /* --forest */
}

.brand__sub {
  margin-top: 16rpx;
  font-size: 30rpx;
  letter-spacing: 0.18em;
  color: #2f6f65;
}

.brand__tagline {
  margin-top: 36rpx;
  font-size: 28rpx;
  letter-spacing: 0.14em;
  color: #587066;
}
