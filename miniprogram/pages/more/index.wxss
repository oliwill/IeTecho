.more-group {
  padding-top: var(--space-card);
  padding-bottom: var(--space-card);
}

.more-item {
  min-height: 48px;
  width: 100%;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--color-text-primary);
  font-size: var(--font-body);
  font-weight: 600;
  text-align: left;
  background: transparent;
  border-top: 1px solid rgba(38, 50, 56, 0.06);
  line-height: 1.4;
}

/* 去掉原生 button 默认边框，保证文字真正左对齐 */
.more-item::after {
  border: none;
}

.more-item:first-of-type {
  margin-top: var(--space-3);
}

.more-item text {
  color: var(--color-text-muted);
  font-size: 22px;
}

.more-copy {
  margin-top: var(--space-3);
  color: var(--color-text-secondary);
  font-size: var(--font-body-small);
  line-height: 1.55;
}
