<view class="page-shell confirm-page">
  <view class="page-title">确认关键指标</view>
  <view class="page-subtitle">确认后的指标才会进入趋势统计。你可以编辑或忽略识别不准的项目。</view>

  <view class="section stack-12">
    <metric-annotation-card
      wx:for="{{metrics}}"
      wx:key="id"
      metric="{{item}}"
      show-actions="{{true}}"
      bind:ignore="ignoreMetric"
      bind:edit="editMetric"
    />
  </view>

  <view class="section card card-soft">
    <view class="section-title">手动添加指标</view>
    <view class="confirm-copy">如果报告里还有重要项目没有识别，可以在正式版本中手动添加。静态 Mock 阶段先展示入口。</view>
    <button class="add-metric" bindtap="showMock">＋ 添加指标</button>
  </view>

  <view class="section">
    <app-button variant="primary" bind:tapbutton="saveToProfile">保存到健康档案</app-button>
  </view>
</view>
