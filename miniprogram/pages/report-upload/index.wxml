<view class="page-shell upload-page">
  <view class="page-title">上传报告</view>
  <view class="page-subtitle">先确认这份报告属于谁，再开始解读。</view>

  <view class="section card">
    <view class="form-label">归属成员</view>
    <view class="member-select">我 <text>默认</text></view>
  </view>

  <view class="section upload-box card card-soft tap-scale" bindtap="chooseMockFile">
    <view class="upload-box__mark">文</view>
    <view class="upload-box__title">{{uploadTitle}}</view>
    <view class="upload-box__desc">{{uploadDescription}}</view>
  </view>

  <view class="section form-card card">
    <view class="form-item">
      <view class="form-label">报告类型</view>
      <view class="chip-row">
        <button class="chip chip--active">体检</button>
        <button class="chip">化验</button>
        <button class="chip">门诊</button>
        <button class="chip">影像</button>
      </view>
    </view>
    <view class="form-item">
      <view class="form-label">报告日期</view>
      <view class="form-static">2026-06-12</view>
    </view>
    <view class="form-item">
      <view class="form-label">医院 / 科室</view>
      <view class="form-static">待填写</view>
    </view>
  </view>

  <view class="section notice-card card">
    <view class="notice-card__title">AI 解读提示</view>
    <view class="notice-card__text">报告解读需要调用第三方 AI 服务，报告文本可能会被发送至模型接口用于生成解读。</view>
  </view>

  <view class="section action-stack">
    <app-button variant="primary" bind:tapbutton="startInterpret">开始解读</app-button>
    <app-button variant="secondary" bind:tapbutton="saveOnly">先保存，不解读</app-button>
  </view>
</view>
