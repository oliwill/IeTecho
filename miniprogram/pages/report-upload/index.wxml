<view class="page-shell upload-page">
  <view class="page-title">上传报告</view>
  <view class="page-subtitle">确认这份报告属于谁，选择文件后提交。</view>

  <view wx:if="{{loadingMembers}}" class="section card">
    <view class="loading-text">加载家人列表…</view>
  </view>

  <block wx:else>
    <!-- 归属成员 -->
    <view class="section card">
      <view class="form-label">归属成员<text wx:if="{{selectedMemberName}}" class="form-label__hint">· 已选 {{selectedMemberName}}</text></view>
      <view class="member-chips">
        <view
          wx:for="{{members}}"
          wx:key="id"
          class="member-chip {{item.id === selectedMemberId ? 'member-chip--active' : ''}}"
          data-id="{{item.id}}"
          catchtap="selectMember"
        >{{item.id === selectedMemberId ? '✓ ' : ''}}{{item.name}}·{{item.relationLabel}}</view>
      </view>
    </view>

    <!-- 文件选择：两个入口 -->
    <view class="section upload-sources card">
      <view class="form-label">报告文件</view>

      <view wx:if="{{filePath}}" class="file-chosen card-soft">
        <view class="file-chosen__icon">✓</view>
        <view class="file-chosen__info">
          <view class="file-chosen__name">{{fileName}}</view>
          <view class="file-chosen__change" catchtap="chooseFile">更换文件</view>
        </view>
      </view>

      <view wx:else class="source-buttons">
        <view class="source-btn tap-scale" catchtap="chooseFile">
          <view class="source-btn__icon">聊</view>
          <view class="source-btn__title">从聊天选择</view>
          <view class="source-btn__desc">微信聊天里收到的 PDF / 图片</view>
        </view>
        <view class="source-btn tap-scale" catchtap="chooseFromAlbum">
          <view class="source-btn__icon">册</view>
          <view class="source-btn__title">从相册选择</view>
          <view class="source-btn__desc">本地相册里的报告照片</view>
        </view>
      </view>
    </view>

    <!-- 报告元信息 -->
    <view class="section form-card card">
      <view class="form-item">
        <view class="form-label">报告类型</view>
        <view class="chip-row">
          <view
            wx:for="{{reportTypes}}"
            wx:key="value"
            class="chip {{item.value === selectedReportType ? 'chip--active' : ''}}"
            data-value="{{item.value}}"
            catchtap="selectReportType"
          >{{item.label}}</view>
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">报告日期</view>
        <picker mode="date" value="{{reportDate}}" bindchange="onDateChange">
          <view class="form-static">{{reportDate}}</view>
        </picker>
      </view>
    </view>

    <!-- 隐私提示 -->
    <view class="section notice-card card">
      <view class="notice-card__title">隐私提示</view>
      <view class="notice-card__text">报告文件上传后存入你的云端档案，仅本人可见。AI 解读（即将开放）会调用第三方模型服务。</view>
    </view>

    <view wx:if="{{errorMsg}}" class="section error-msg">{{errorMsg}}</view>

    <view class="submit-spacer"></view>
  </block>

  <!-- 提交：固定底部，永远可见 -->
  <view wx:if="{{!loadingMembers}}" class="submit-bar">
    <app-button variant="primary" bind:tapbutton="saveOnly" loading="{{uploading}}">{{uploading ? '上传中…' : '保存报告'}}</app-button>
  </view>
</view>
