.form-label {
  margin-bottom: var(--space-2);
  color: var(--color-text-primary);
  font-size: var(--font-body-small);
  font-weight: 800;
}

.form-label__hint {
  margin-left: var(--space-1);
  color: var(--color-primary-deep);
  font-weight: 700;
}

.form-static {
  min-height: 44px;
  display: flex;
  align-items: center;
  border-radius: var(--radius-md);
  background: var(--color-surface-soft);
  padding: 0 14px;
  color: var(--color-text-primary);
  font-size: var(--font-body);
  font-weight: 700;
}

.form-item {
  margin-top: var(--space-4);
}

.form-item:first-child {
  margin-top: 0;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.chip-row--center {
  justify-content: center;
}

.chip {
  min-height: 40px;
  padding: 0 14px;
  border-radius: var(--radius-pill);
  background: var(--color-surface-soft);
  color: var(--color-text-secondary);
  font-size: var(--font-body-small);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip--active {
  background: var(--color-primary-soft);
  color: var(--color-primary-deep);
}

.notice-card__title {
  font-size: var(--font-card-title);
  font-weight: 800;
}

.notice-card__text {
  margin-top: var(--space-2);
  color: var(--color-text-secondary);
  font-size: var(--font-body-small);
  line-height: 1.55;
}

/* 成员选择 chip 组 */
.member-chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.member-chip {
  min-height: 44px;
  padding: 0 16px;
  border-radius: var(--radius-pill);
  background: var(--color-surface-soft);
  color: var(--color-text-secondary);
  font-size: var(--font-body-small);
  font-weight: 700;
  display: flex;
  align-items: center;
}

.member-chip--active {
  background: var(--color-primary-soft);
  color: var(--color-primary-deep);
}

/* 文件来源 */
.upload-sources {
  /* 继承 card */
}

.source-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
  margin-top: var(--space-2);
}

.source-btn {
  padding: var(--space-4) var(--space-3);
  border-radius: var(--radius-lg);
  background: var(--color-surface-soft);
  text-align: center;
}

.source-btn__icon {
  margin: 0 auto var(--space-2);
  color: var(--color-primary-deep);
  display: flex;
  align-items: center;
  justify-content: center;
}

.source-btn__svg {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.source-btn__title {
  color: var(--color-text-primary);
  font-size: var(--font-body-small);
  font-weight: 800;
}

.source-btn__desc {
  margin-top: 2px;
  color: var(--color-text-muted);
  font-size: var(--font-caption);
  line-height: 1.4;
}

.file-chosen {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3);
  border-radius: var(--radius-lg);
  margin-top: var(--space-2);
}

.file-chosen__icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  background: var(--color-status-normal);
  color: var(--color-text-inverse);
  font-size: var(--font-card-title);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.file-chosen__name {
  color: var(--color-text-primary);
  font-size: var(--font-body-small);
  font-weight: 700;
  word-break: break-all;
}

.file-chosen__change {
  margin-top: 2px;
  color: var(--color-primary-deep);
  font-size: var(--font-caption);
}

/* 固定底部提交栏 */
.submit-spacer {
  height: 100px;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--space-3) var(--space-page-x) calc(env(safe-area-inset-bottom) + var(--space-3));
  background: var(--color-surface);
  box-shadow: 0 -4px 16px rgba(38, 50, 56, 0.08);
  z-index: 10;
}

/* 加载与错误 */
.loading-text {
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-body-small);
  padding: var(--space-3) 0;
}

.error-msg {
  color: var(--color-status-warning);
  font-size: var(--font-body-small);
  text-align: center;
}
