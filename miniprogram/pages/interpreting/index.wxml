<view class="page-shell interpreting-page">
  <view class="interpreting-card card card-soft">
    <view class="interpreting-card__pulse">AI</view>
    <view class="page-title">正在整理报告重点</view>
    <view class="page-subtitle">这不是诊断结果，只用于帮助理解报告。</view>

    <view class="step-list">
      <view class="step-item step-item--done">读取报告内容</view>
      <view class="step-item step-item--done">整理异常指标</view>
      <view class="step-item step-item--active">生成通俗解释</view>
      <view class="step-item">准备确认指标</view>
    </view>
  </view>

  <view class="section action-stack">
    <app-button variant="primary" bind:tapbutton="goResult">查看解读结果</app-button>
    <app-button variant="secondary" bind:tapbutton="goBackLater">稍后查看</app-button>
  </view>
</view>
