page {
  /* 品牌主色：深绿体系（源自 OpenDesign home.html，2026-06-18 确认） */
  --color-primary: #4f7765;
  --color-primary-deep: #36594c;
  --color-primary-soft: #e7f1ec;
  --color-primary-muted: #d5e2d5;

  /* 页面和表面 */
  --color-page: #e7efec;
  --color-surface: #fffdf8;
  --color-surface-soft: #e2eee8;
  --color-surface-warm: #fffdf8;

  /* 文本 */
  --color-text-primary: #32443c;
  --color-text-secondary: #587066;
  --color-text-muted: #8ea399;
  --color-text-inverse: #ffffff;

  /* 状态色：源自 home.html，柔和非医疗恐吓 */
  --color-status-normal: #4f7765;
  --color-status-attention: #d9a35b;
  --color-status-warning: #c96f5f;
  --color-status-info: #7aa6ad;
  --color-status-done: #789b67;

  /* 字号 */
  --font-page-title: 24px;
  --font-section-title: 20px;
  --font-card-title: 18px;
  --font-body: 16px;
  --font-body-small: 15px;
  --font-caption: 13px;
  --font-number-large: 24px;
  --font-number: 20px;

  /* 间距：4px 栅格 */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;
  --space-page-x: 16px;
  --space-section-y: 20px;
  --space-card: 16px;
  --space-card-large: 20px;
  --space-inline: 8px;

  /* 圆角 */
  --radius-sm: 8px;
  --radius-md: 14px;
  --radius-lg: 18px;
  --radius-xl: 22px;
  --radius-pill: 999px;

  /* 阴影 */
  --shadow-card: 0 10px 28px rgba(38, 50, 56, 0.09);
  --shadow-card-soft: 0 4px 14px rgba(38, 50, 56, 0.06);
  --shadow-floating: 0 8px 24px rgba(38, 50, 56, 0.12);

  /* 动效 */
  --duration-tap: 100ms;
  --duration-card-enter: 200ms;
  --duration-highlight: 200ms;
  --duration-expand: 260ms;
  --ease-standard: cubic-bezier(0.2, 0, 0, 1);

  /* 边框 */
  --color-border: rgba(70, 101, 86, 0.16);
}
